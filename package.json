{
  "name": "changelog-sh",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "cd apps/server && bun --watch src/index.ts",
    "dev:dash": "cd apps/dashboard && bun run dev",
    "build": "bun run --filter '*' build",
    "lint": "eslint . --ext .ts,.vue",
    "typecheck": "tsc --noEmit -p tsconfig.json && cd apps/server && tsc --noEmit && cd ../dashboard && bun run typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "bun-types": "^1.3.13",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.15.1",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
