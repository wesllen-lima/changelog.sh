# ── Required ──────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-character-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=3456
DB_PATH=./data/changelog.db
NODE_ENV=development

# Origin allowed by CORS and Better Auth (set this in production)
# ALLOWED_ORIGIN=https://changelog.yourdomain.com

# ── Magic link auth (requires Resend account) ─────────────────────────────────
# When set, login switches to passwordless magic link mode
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=changelog.sh <noreply@yourdomain.com>

# ── Cloud database (Turso) — replaces local SQLite ───────────────────────────
# DATABASE_URL=libsql://your-database.turso.io
# DATABASE_AUTH_TOKEN=eyJhbGciOiJFZERTQSJ9...
